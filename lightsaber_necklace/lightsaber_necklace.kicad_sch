  (text "ideal diodes are an idea, LM74700\nbut they use 100 uA which is too much for amorphous panels\nmax40203 might work\n\ndiodes are doubled to provide the nets without sequential voltage loss"
    (at 177.8 59.69 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 0abf763f-9ebf-4e73-ad4c-b22a956db844)
  )
  (text "Every part must be considered for leakage current\n\n\nHybrid supercaps must stay above 2.2V, so only with green LEDS (3.2 working volts)\nELDC supercaps can't go above 2.85V, so not with open circuit voltages higher than that\n\nLED is primarly under voltage control with the resistor there as a fallback"
    (at 13.97 171.45 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 0f7c4b2a-6784-4aa9-86ad-8c6c47c1d3b9)
  )
  (text "Red (1.5V - 2.2V) + ELDC + max 2.76 solar\nGreen (2.5 - 3.2V) + Hybrid + 3.4/4.2V solar\nWhite (2.2 - 2.7) + large ELDC +  larger max 2.76 solar"
    (at 165.1 125.73 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 27614a4d-e316-4cab-a726-71fdd49e8fe2)
  )
  (text "multiple LED and polyfuse size options, footprints overlap"
    (at 101.6 180.34 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 2acf1057-006f-4ac0-adc1-7970b365a682)
  )
  (text "Light only on in dark" (at 120.65 142.24 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid 35e7518b-145c-4af2-9170-be2d436eb5e5)
  )

